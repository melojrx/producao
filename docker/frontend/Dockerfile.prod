# syntax=docker/dockerfile:1
# Next.js producao — imagem standalone otimizada (MDJ-18)
# Build context: raiz do repositorio

FROM node:20-alpine AS deps

WORKDIR /app

COPY package.json package-lock.json ./
RUN npm ci

FROM node:20-alpine AS builder

WORKDIR /app

COPY --from=deps /app/node_modules ./node_modules
COPY . .

ARG NEXT_PUBLIC_DJANGO_API_URL=http://localhost:8080
ARG NEXT_PUBLIC_SUPABASE_URL=
ARG NEXT_PUBLIC_SUPABASE_ANON_KEY=
ARG NEXT_PUBLIC_USE_DJANGO_SCANNER_READS=false
ARG NEXT_PUBLIC_USE_DJANGO_CADASTROS_READS=false
ARG NEXT_PUBLIC_USE_DJANGO_METAS_READS=false
ARG NEXT_PUBLIC_USE_DJANGO_DASHBOARD_READS=false
ARG NEXT_PUBLIC_USE_DJANGO_AUTH=false
ARG NEXT_PUBLIC_USE_DJANGO_ADMIN_WRITES=false
ARG NEXT_PUBLIC_USE_DJANGO_PRODUCAO_WRITES=false
ARG NEXT_PUBLIC_USE_DJANGO_QUALIDADE_WRITES=false

ENV NEXT_PUBLIC_DJANGO_API_URL=$NEXT_PUBLIC_DJANGO_API_URL
ENV NEXT_PUBLIC_SUPABASE_URL=$NEXT_PUBLIC_SUPABASE_URL
ENV NEXT_PUBLIC_SUPABASE_ANON_KEY=$NEXT_PUBLIC_SUPABASE_ANON_KEY
ENV NEXT_PUBLIC_USE_DJANGO_SCANNER_READS=$NEXT_PUBLIC_USE_DJANGO_SCANNER_READS
ENV NEXT_PUBLIC_USE_DJANGO_CADASTROS_READS=$NEXT_PUBLIC_USE_DJANGO_CADASTROS_READS
ENV NEXT_PUBLIC_USE_DJANGO_METAS_READS=$NEXT_PUBLIC_USE_DJANGO_METAS_READS
ENV NEXT_PUBLIC_USE_DJANGO_DASHBOARD_READS=$NEXT_PUBLIC_USE_DJANGO_DASHBOARD_READS
ENV NEXT_PUBLIC_USE_DJANGO_AUTH=$NEXT_PUBLIC_USE_DJANGO_AUTH
ENV NEXT_PUBLIC_USE_DJANGO_ADMIN_WRITES=$NEXT_PUBLIC_USE_DJANGO_ADMIN_WRITES
ENV NEXT_PUBLIC_USE_DJANGO_PRODUCAO_WRITES=$NEXT_PUBLIC_USE_DJANGO_PRODUCAO_WRITES
ENV NEXT_PUBLIC_USE_DJANGO_QUALIDADE_WRITES=$NEXT_PUBLIC_USE_DJANGO_QUALIDADE_WRITES

ENV NEXT_TELEMETRY_DISABLED=1

RUN npm run build

FROM node:20-alpine AS runner

WORKDIR /app

ENV NODE_ENV=production
ENV NEXT_TELEMETRY_DISABLED=1
ENV PORT=3000
ENV HOSTNAME=0.0.0.0

RUN addgroup --system --gid 1001 nodejs \
  && adduser --system --uid 1001 nextjs

COPY --from=builder /app/public ./public
COPY --from=builder --chown=nextjs:nodejs /app/.next/standalone ./
COPY --from=builder --chown=nextjs:nodejs /app/.next/static ./.next/static

USER nextjs

EXPOSE 3000

CMD ["node", "server.js"]
