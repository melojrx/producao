# syntax=docker/dockerfile:1
# Next.js dev — hot-reload via volume mount no compose (MDJ-17)
# Build context: raiz do repositorio (../.. a partir de docker/compose/)

FROM node:20-alpine

WORKDIR /app

COPY package.json package-lock.json ./
RUN npm ci

EXPOSE 3000

CMD ["npm", "run", "dev", "--", "--hostname", "0.0.0.0", "--port", "3000"]
