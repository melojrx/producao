# Variaveis de ambiente — referencia
#
# DEV (MDJ-16/17):
#   Stack integrada: npm run dev:docker
#   Frontend no host: .env.local com NEXT_PUBLIC_DJANGO_API_URL=http://localhost:8001
#   Guia: docker/README.md
#
# PRODUCAO LOCAL (MDJ-18 — homologar compose, sem deploy VPS):
#   cp .env.example .env  →  preencher secrets  →  npm run prod:docker
#   Smoke: node scripts/smoke-stack-prod.mjs  (base http://localhost:8080)
#
# PRODUCAO VPS (MDJ-21 — deploy em producao.costurai.com.br):
#   Runbook: docs/migracao_django/MDJ21_RUNBOOK_DEPLOY_VPS.md
#   Mesmo .env na VPS; PROD_HTTP_PORT=80; SECURE_*=true; TLS no proxy

# --- Django (producao — MDJ-18) ---
DJANGO_SECRET_KEY=change-me-to-a-long-random-secret
ALLOWED_HOSTS=localhost,127.0.0.1,backend,producao.costurai.com.br
BACKEND_PORT=8002
PROD_HTTP_PORT=8080

# --- PostgreSQL ---
POSTGRES_DB=pcp_db
POSTGRES_USER=pcp_user
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_CONN_MAX_AGE=60

# --- Media local (volume Docker media_data) ---
MEDIA_URL=/media/
MEDIA_BASE_URL=https://producao.costurai.com.br
STATIC_URL=/static/

# --- Storage S3 (FORA DE ESCOPO — nao usar) ---
USE_S3_STORAGE=false

# --- Seguranca HTTPS (homologacao local: false; VPS com TLS: true) ---
SECURE_SSL_REDIRECT=false
SESSION_COOKIE_SECURE=false
CSRF_COOKIE_SECURE=false
SECURE_HSTS_SECONDS=0

# --- CORS / CSRF (dominio unico producao.costurai.com.br) ---
# Com nginx no mesmo host, browser e API compartilham origem — CORS raramente necessario.
# Manter configurado para chamadas cross-origin futuras ou ferramentas externas.
CORS_ALLOWED_ORIGINS=https://producao.costurai.com.br
CSRF_TRUSTED_ORIGINS=https://producao.costurai.com.br

# --- Frontend producao (build-time — rebuild ao alterar) ---
# Homologacao local via proxy nginx:
NEXT_PUBLIC_DJANGO_API_URL=http://localhost:8080
# VPS (apos deploy):
# NEXT_PUBLIC_DJANGO_API_URL=https://producao.costurai.com.br

# Supabase + flags MDJ-16 (copiar de .env.local; OFF ate cutover em producao)
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_USE_DJANGO_SCANNER_READS=false
NEXT_PUBLIC_USE_DJANGO_CADASTROS_READS=false
NEXT_PUBLIC_USE_DJANGO_METAS_READS=false
NEXT_PUBLIC_USE_DJANGO_DASHBOARD_READS=false
NEXT_PUBLIC_USE_DJANGO_AUTH=false
NEXT_PUBLIC_USE_DJANGO_ADMIN_WRITES=false
NEXT_PUBLIC_USE_DJANGO_PRODUCAO_WRITES=false
NEXT_PUBLIC_USE_DJANGO_QUALIDADE_WRITES=false

# --- Observabilidade ---
LOG_LEVEL=INFO

# Smoke prod contra VPS (apos MDJ-21):
# SMOKE_PROD_BASE_URL=https://producao.costurai.com.br
# SMOKE_ADMIN_EMAIL=
# SMOKE_ADMIN_PASSWORD=

# --- VPS pos-deploy ---
# PROD_HTTP_PORT=80
# Agendar scripts/infra/backup_postgres.sh e backup_media.sh via cron
# Nao expor db nem backend diretamente — apenas proxy (porta 80/443)
