# Variaveis de ambiente — referencia
#
# Padrao atual: Django + PostgreSQL em Docker; flags ON por default.
#
# DEV:
#   Stack integrada:    npm run dev:docker            (frontend + backend + db via Docker)
#   Frontend no host:   npm run dev                   (.env.local com NEXT_PUBLIC_DJANGO_API_URL=http://localhost:8001)
#   Guia:               docker/README.md
#
# PRODUCAO LOCAL (homologar compose, sem deploy VPS):
#   cp .env.example .env  ->  preencher secrets  ->  npm run prod:docker
#   Smoke: node scripts/smoke-stack-prod.mjs  (base http://localhost:8080)
#
# PRODUCAO VPS (producao.costurai.com.br):
#   Runbook: docs/migracao_django/MDJ21_RUNBOOK_DEPLOY_VPS.md
#   Mesmo .env na VPS; PROD_HTTP_PORT=8080; TLS no nginx HOST; SECURE_SSL_REDIRECT=false no container

# --- Django ---
DJANGO_SECRET_KEY=change-me-to-a-long-random-secret
ALLOWED_HOSTS=localhost,127.0.0.1,backend,producao.costurai.com.br
BACKEND_PORT=8002
PROD_HTTP_PORT=8080

# --- PostgreSQL ---
POSTGRES_DB=pcp_db
POSTGRES_USER=pcp_user
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_CONN_MAX_AGE=60

# --- Media local (volume Docker media_data) ---
MEDIA_URL=/media/
MEDIA_BASE_URL=https://producao.costurai.com.br
STATIC_URL=/static/

# --- Storage S3 (FORA DE ESCOPO — nao usar) ---
USE_S3_STORAGE=false

# --- Seguranca HTTPS (homologacao local: false; VPS com TLS no nginx HOST: false no container) ---
# O nginx host termina TLS e envia X-Forwarded-Proto; redirect 80->443 e no edge, nao no Django.
SECURE_SSL_REDIRECT=false
SESSION_COOKIE_SECURE=true
CSRF_COOKIE_SECURE=true
SECURE_HSTS_SECONDS=31536000

# --- CORS / CSRF (dominio unico producao.costurai.com.br) ---
# Com nginx no mesmo host, browser e API compartilham origem — CORS raramente necessario.
# Manter configurado para chamadas cross-origin futuras ou ferramentas externas.
CORS_ALLOWED_ORIGINS=https://producao.costurai.com.br
CSRF_TRUSTED_ORIGINS=https://producao.costurai.com.br

# --- Frontend producao (build-time — rebuild ao alterar) ---
# Homologacao local via proxy nginx:
NEXT_PUBLIC_DJANGO_API_URL=http://localhost:8080
# VPS (apos deploy):
# NEXT_PUBLIC_DJANGO_API_URL=https://producao.costurai.com.br

# --- Flags de cutover Django (padrao: ON) ---
# Estas flags ligam as rotas Django no frontend. Mantenha ON para operacao normal.
# Para rollback emergencial (nao recomendado apos cutover em producao), altere para false
# e descomente as variaveis de conexao legada na secao abaixo.
NEXT_PUBLIC_USE_DJANGO_SCANNER_READS=true
NEXT_PUBLIC_USE_DJANGO_CADASTROS_READS=true
NEXT_PUBLIC_USE_DJANGO_METAS_READS=true
NEXT_PUBLIC_USE_DJANGO_DASHBOARD_READS=true
NEXT_PUBLIC_USE_DJANGO_AUTH=true
NEXT_PUBLIC_USE_DJANGO_ADMIN_WRITES=true
NEXT_PUBLIC_USE_DJANGO_PRODUCAO_WRITES=true
NEXT_PUBLIC_USE_DJANGO_QUALIDADE_WRITES=true

# Runtime SSR (Docker/VPS) — nao embutido no bundle; espelha NEXT_PUBLIC_* em producao
USE_DJANGO_SCANNER_READS=true
USE_DJANGO_CADASTROS_READS=true
USE_DJANGO_METAS_READS=true
USE_DJANGO_DASHBOARD_READS=true
USE_DJANGO_AUTH=true
USE_DJANGO_ADMIN_WRITES=true
USE_DJANGO_PRODUCAO_WRITES=true
USE_DJANGO_QUALIDADE_WRITES=true

# --- Conexao legada (ROLLBACK APENAS — manter comentada em operacao normal) ---
# Usada apenas em rollback emergencial pos-cutover. Em operacao normal permanece comentada.
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=

# --- Observabilidade ---
LOG_LEVEL=INFO

# Smoke prod contra VPS:
# SMOKE_PROD_BASE_URL=https://producao.costurai.com.br
# SMOKE_ADMIN_EMAIL=
# SMOKE_ADMIN_PASSWORD=

# --- VPS pos-deploy ---
# PROD_HTTP_PORT=80
# Agendar scripts/infra/backup_postgres.sh e backup_media.sh via cron
# Nao expor db nem backend diretamente — apenas proxy (porta 80/443)