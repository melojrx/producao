# Variaveis de ambiente — stack Django de producao (docker-compose.prod.yml)
# Copie para .env na raiz e ajuste antes de subir a stack.

# --- Django ---
DJANGO_SECRET_KEY=change-me-to-a-long-random-secret
ALLOWED_HOSTS=localhost,127.0.0.1,api.seudominio.com.br
BACKEND_PORT=8002

# --- PostgreSQL ---
POSTGRES_DB=pcp_db
POSTGRES_USER=pcp_user
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_CONN_MAX_AGE=60

# --- Media local (padrao: volume Docker media_data) ---
MEDIA_URL=/media/
MEDIA_BASE_URL=https://api.seudominio.com.br
# MEDIA_ROOT=/app/media  # padrao no container

# --- Storage S3 (opcional; desligado por padrao) ---
USE_S3_STORAGE=false
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_STORAGE_BUCKET_NAME=pcp-media
# AWS_S3_REGION_NAME=us-east-1
# AWS_S3_CUSTOM_DOMAIN=cdn.seudominio.com.br
# AWS_DEFAULT_ACL=public-read
# AWS_QUERYSTRING_AUTH=false

# --- Seguranca HTTPS (ativar atras de proxy TLS / EasyPanel) ---
SECURE_SSL_REDIRECT=false
SESSION_COOKIE_SECURE=false
CSRF_COOKIE_SECURE=false
SECURE_HSTS_SECONDS=0

# --- Observabilidade ---
LOG_LEVEL=INFO

# --- EasyPanel / VPS ---
# Publicar apenas backend:8000 atras do reverse proxy.
# Nao expor db na internet. Agendar backup_postgres.sh e backup_media.sh via cron.
